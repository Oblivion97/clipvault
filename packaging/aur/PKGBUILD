# Maintainer: YOUR_NAME <your@email.com>
pkgname=clipvault
pkgver=1.4.0
pkgrel=1
pkgdesc="Windows-style clipboard history manager for Linux (Win+V)"
arch=('any')
url="https://github.com/Oblivion97/clipvault"
license=('MIT')
depends=(
    'python'
    'python-gobject'
    'gtk3'
    'xdotool'
    'wl-clipboard'
)
optdepends=(
    'python-pynput: Win+V hotkey on X11'
    'ydotool: auto-paste on Wayland'
    'wtype: auto-paste on Wayland (alternative to ydotool)'
)
makedepends=('python-pip')
source=("$pkgname-$pkgver.tar.gz::https://github.com/Oblivion97/clipvault/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('f1b8636c27b483c79cdc9d10627365d7b6a854ce98b82f1fec5e0fa01dcce30f')   # replace with actual sha256 after first release

package() {
    cd "$srcdir/$pkgname-$pkgver"

    # Main script
    install -Dm755 clipvault.py "$pkgdir/usr/bin/clipvault"

    # Desktop file
    install -Dm644 packaging/io.github.clipvault.ClipVault.desktop \
        "$pkgdir/usr/share/applications/io.github.clipvault.ClipVault.desktop"

    # Icon
    install -Dm644 assets/icon.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/io.github.clipvault.ClipVault.svg"

    # AppStream metadata
    install -Dm644 packaging/io.github.clipvault.ClipVault.appdata.xml \
        "$pkgdir/usr/share/metainfo/io.github.clipvault.ClipVault.appdata.xml"

    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
